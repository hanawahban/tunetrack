{
  "openapi": "3.0.3",
  "info": {
    "title": "TuneTrack API",
    "description": "Last.fm-style music scrobbling API",
    "version": "1.0"
  },
  "components": {
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {}
        }
      }
    },
    "/auth/register": {
      "post": {
        "parameters": [],
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "email": {
                      "type": "string"
                    },
                    "role": {
                      "anyOf": [
                        {
                          "const": "ADMIN",
                          "type": "string"
                        },
                        {
                          "const": "CURATOR",
                          "type": "string"
                        },
                        {
                          "const": "LISTENER",
                          "type": "string"
                        }
                      ]
                    },
                    "createdAt": {
                      "format": "date-time",
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "email",
                    "role",
                    "createdAt"
                  ]
                }
              },
              "multipart/form-data": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "email": {
                      "type": "string"
                    },
                    "role": {
                      "anyOf": [
                        {
                          "const": "ADMIN",
                          "type": "string"
                        },
                        {
                          "const": "CURATOR",
                          "type": "string"
                        },
                        {
                          "const": "LISTENER",
                          "type": "string"
                        }
                      ]
                    },
                    "createdAt": {
                      "format": "date-time",
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "email",
                    "role",
                    "createdAt"
                  ]
                }
              },
              "text/plain": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "email": {
                      "type": "string"
                    },
                    "role": {
                      "anyOf": [
                        {
                          "const": "ADMIN",
                          "type": "string"
                        },
                        {
                          "const": "CURATOR",
                          "type": "string"
                        },
                        {
                          "const": "LISTENER",
                          "type": "string"
                        }
                      ]
                    },
                    "createdAt": {
                      "format": "date-time",
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "email",
                    "role",
                    "createdAt"
                  ]
                }
              }
            }
          }
        },
        "operationId": "postAuthRegister",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "format": "email",
                    "type": "string"
                  },
                  "password": {
                    "minLength": 8,
                    "type": "string"
                  }
                }
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "format": "email",
                    "type": "string"
                  },
                  "password": {
                    "minLength": 8,
                    "type": "string"
                  }
                }
              }
            },
            "text/plain": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "format": "email",
                    "type": "string"
                  },
                  "password": {
                    "minLength": 8,
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
