  "info": {
    "title": "TuneTrack API",
    "description": "Last.fm-style music scrobbling API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateAlbumDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "releaseYear": {
            "type": "number"
          },
          "imageUrl": {
            "type": "string",
            "format": "uri"
          },
          "artistId": {
            "type": "number"
          }
        },
        "required": [
          "title",
          "artistId"
        ]
      },
      "TrackResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "title": {
            "type": "string"
          },
          "albumId": {
            "type": "number"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "album": {
            "$ref": "#/components/schemas/AlbumResponseDto"
          }
        },
        "required": [
          "id",
          "title",
          "albumId",
          "createdAt"
        ]
      },
      "AlbumResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "title": {
            "type": "string"
          },
          "releaseYear": {
            "type": "number",
            "nullable": true
          },
          "imageUrl": {
            "type": "string",
            "nullable": true
          },
          "artistId": {
            "type": "number"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "artist": {
            "$ref": "#/components/schemas/ArtistResponseDto"
          },
          "tracks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TrackResponseDto"
            }
          }
        },
        "required": [
          "id",
          "title",
          "artistId",
          "createdAt"
        ]
      },
      "ArtistResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "albums": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AlbumResponseDto"
            }
          }
        },
        "required": [
          "id",
          "name",
          "createdAt"
        ]
      },
      "UpdateAlbumDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "releaseYear": {
            "type": "number"
          },
          "imageUrl": {
            "type": "string",
            "format": "uri"
          },
          "artistId": {
            "type": "number"
          }
        }
      },
      "CreateArtistDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateArtistDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "CreateTrackDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "albumId": {
            "type": "number"
          }
        },
        "required": [
          "title",
          "albumId"
        ]
      },
      "UpdateTrackDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "albumId": {
            "type": "number"
          }
        }
      },
      "UpdateRoleDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "object"
          }
        },
        "required": [
          "role"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "CURATOR",
              "LISTENER"
            ]
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "role",
          "createdAt"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          }
        },
        "required": [
          "access_token"
        ]
      },
      "CreateScrobbleDto": {
        "type": "object",
        "properties": {
          "trackId": {
            "type": "number"
          }
        },
        "required": [
          "trackId"
        ]
      },
      "ScrobbleResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "userId": {
            "type": "number"
          },
          "trackId": {
            "type": "number"
          },
          "playedAt": {
            "format": "date-time",
            "type": "string"
          },
          "track": {
            "$ref": "#/components/schemas/TrackResponseDto"
          }
        },
        "required": [
          "id",
          "userId",
          "trackId",
          "playedAt"
        ]
      },
      "TopArtistDto": {
        "type": "object",
        "properties": {
          "artistId": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "playCount": {
            "type": "number"
          }
        },
        "required": [
          "artistId",
          "name",
          "playCount"
        ]
      }
    }
  }
}